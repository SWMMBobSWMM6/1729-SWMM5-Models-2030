/*  Special Structure XPX Format */
/*  All special structures defined as multiple links in EXTRAN, */
/*  with link type 138, rather than type 136                    */

Link 138 "P75223" "5223" "75223"
DATA CNAME1 "P75223" 0 7 "P75223" "" "" "" "" "" ""
DATA SCF1 "P75223" 1 1 oneq  /* Always write like this */
DATA SCF2 "P75223" 1 1 CDM  /* Always write like this */
DATA SCF4 "P75223" 1 1 5000  /* Always write like this */
DATA SC4V1 "P75223" 1 1 0  /* Always write like this */
DATA SC4V2 "P75223" 1 1 0  /* Always write like this */
DATA SC4V3 "P75223" 1 1 20  /* Flow through valve - from EPANET link 75223*/
DATA SC4V4 "P75223" 1 1 87  /* Head loss thru structure - from DB Q-HL Lookup Table */

DATA SPECNAME "P75223" 1 1 LiveOakPCS  /* Structure name max 10 char */
DATA SPECDIV "P75223" 1 1 999   /* Always write like this */
DATA SPEC1 "P75223" 0 1 1   /* Always write like this */

DATA CNAME1 "P75223" 0 1 P75223  /* Special Structure ID */
DATA COND1 "P75223" 0 1 1    /* Always write like this */

/* Conduit Data 
DATA NKLASS "P75223" 0 1 1  /* Always write like this */
DATA PLTCOND 'P75223' 0 1 "1" /* Dummy cond. plot definition */
DATA NKLASS "P75223" 1 1 1  /* Always write like this */
DATA LEN "P75223" 1 1 33   /* Lenght - Always 33 feet */
DATA DEEP "P75223" 1 1 8  /*Diam. - EPANET valve Diam. */

DATA ROUGH "P75223" 1 1 0.014  /* Roughness - always 0.014 */

/* The following define the conduit endpoint elevations and */
/* are the same elevation as the adjacent junction inverts.*/
DATA ZP1 "P75223" 1 1 1567
DATA ZP2 "P75223" 1 1 1567

