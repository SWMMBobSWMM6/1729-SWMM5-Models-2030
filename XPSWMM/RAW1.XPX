/*  All special structures defined as multiple links in EXTRAN, */
/*  with link type 138, rather than type 136                    */

Link 138 "P75405" "5405" "75405"
DATA CNAME1 "P75405" 0 7 "P75405" "" "" "" "" "" ""
DATA SCF1 "P75405" 1 1 oneq  /* Always write like this */
DATA SCF2 "P75405" 1 1 CDM  /* Always write like this */
DATA SCF4 "P75405" 1 1 5000  /* Always write like this */
DATA SC4V1 "P75405" 1 1 0  /* Always write like this */
DATA SC4V2 "P75405" 1 1 0  /* Always write like this */
DATA SC4V3 "P75405" 1 1 222.5  /* Flow through valve - from EPANET link 75223*/
DATA SC4V4 "P75405" 1 1 151.3  /* Head loss thru structure - from DB Q-HL Lookup Table */

DATA SPECNAME "P75405" 1 1 TemescalPP  /* Structure name max 10 char */
DATA SPECDIV "P75405" 1 1 999   /* Always write like this */
DATA SPEC1 "P75405" 0 1 1   /* Always write like this */

