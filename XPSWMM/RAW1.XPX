/*********************************************************/
/*                                                       */
/*                                                       */
/*   Define Job Control Information                      */
/*                                                       */
/*********************************************************/
DATA ALPHA "" 0 1 "This is an XPX File"
DATA ALPHB "" 0 1 "Second line of the XPX file"
DATA MODE "" 0 1 "2"         /*Extran Mode */

DATA MOZERO "" 0 1 1    /* Start Month = 1 */
DATA YZERO "" 0 1 96     /* Start Year = 96 */
DATA DZERO "" 0 1 1    /* Start Day = 1 */
DATA HZERO "" 0 1 0    /* Start Hour = zero */
DATA MZERO "" 0 1 0    /* Start Month = 1 */
DATA SZERO "" 0 1 0    /* Start Seconds = Zero */
/*********************************************************/
/*                                                       */
/*   Define Duration of Simulation                       */
/*********************************************************/
DATA YSL "" 0 1 96     /* Duration Year = 96 */
DATA MSL "" 0 1 1     /* Duration Month = 1 */
DATA DSL "" 0 1 1     /* Duration Day = 1 */
DATA HSL "" 0 1 3     /* Duraton Hour = 3 */
DATA SSL "" 0 1 0     /* Duration Second = Zero */
/*********************************************************/
/*                                                       */
/*  Define Time Steps                                    */
/*                                                       */
/*********************************************************/
DATA DELT "" 0 1 10     /* Time step = 10 seconds */
/*********************************************************/
/*                                                       */
/*  Define Printout Intervals                            */
/*                                                       */
/*********************************************************/
DATA CNTLOC "" 0 1 "1"     /* Output Control Flag On    */
DATA CNTLNS "" 0 1 "1"     /* Echo Nat Surface On */
DATA NSTART "" 0 1 45      /* Starting Time step for Printout */
DATA INTER "" 0 1 1000      /* Intermediate Print Cycle */
DATA JNTER "" 0 1 1000      /* Summary Print Cycle */
/*********************************************************/
/*                                                       */
/*   Switch off all options in Job Control               */
/*                                                       */
/*********************************************************/
DATA CNTLR "" 0 1 1     /* Routing Control On  */
DATA OMEGA "" 0 1 0.85     /* Under Relaxation Parameter */
DATA WD "" 0 1 0.65      /* Time Weighting Parameter */
DATA FMAX "" 0 1 1.0     /* Conduit Roughness Factor */
DATA QREF "" 0 1 1.0     /* Flow Adjustment Factor    */
DATA ISMTH "" 0 1 1    /* Number of smoothing steps */
DATA FMIN "" 0 1 1.0      /* Courant Time Step Factor */
DATA MFAIL "" 0 1 30      /* Number of Iterations */
DATA KINE "" 0 1 "2"     /* EPA Solution */
DATA ISOL "" 0 1 "0"     /* Explicit Scheme */
DATA KSUPER "" 0 1 "0"     /* Supercritical Options */

DATA CNTLMC "" 0 1 "1"     /*Modify Conduits Flag On */
DATA NEQUALF "" 0 1 "1"     /* Modify Conduits On */
DATA NEQUAL "" 0 1 10      /* Modify Conduits Time Step */

DATA CNTLJD "" 0 1 1      /* Junction Defaults On */
DATA AMEN "" 0 1 12.5      /* Default Surface Area */
DATA FUDGE "" 0 1 0.001     /* Minimum Junction Depth */
DATA AJ1 "" 0 1 500.0      /* Ponding Depth Coefficient */
DATA AJ2 "" 0 1 1e-5      /* Pond Depth Exponent */

DATA CNTLH "" 0 1 1      /* HOT START ON */
DATA REDO "" 0 1 2      /* Create Hot-Restart File */
DATA HOTFN "" 0 1 "FILE.HOT"     /*Hot-Restart File Name */

DATA CNTLT "" 0 1 1      /* Simulation Tolerances On */
DATA SURTOL "" 0 1 0.05      /* Flow Tolerance */
DATA SURJUN "" 0 1 0.001     /* Head Tolerance */
DATA ORMIN "" 0 1 300.0      /* Minimum orifice/weir length */
DATA HLOSS "" 0 1 0.00      /* Default Head Loss */
DATA CLOSS "" 0 1 0.00      /* Default Contraction Loss */
