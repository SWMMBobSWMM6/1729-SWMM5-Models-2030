DATA DEEP "P75405" 1 1 9  /*Diam. - EPANET valve Diam. */

DATA ROUGH "P75405" 1 1 0.014  /* Roughness - always 0.014 */

/* The following define the conduit endpoint elevations and */
/* are the same elevation as the adjacent junction inverts.*/
DATA ZP1 "P75405" 1 1 1079
DATA ZP2 "P75405" 1 1 1079

