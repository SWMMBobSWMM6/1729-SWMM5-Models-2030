CHs_CalibRef::CHs_CalibRef()
//
//  Description : constructor
//
{
//
//
//  ** Class Data **
//
 mv_pNetwork       = NULL;
 mv_pollutantCount = 0;
//
 mv_calibCount  = 0;
 mv_pCalibIndex = NULL;
 mv_pCalibData  = NULL;
//
 mv_pFile     = NULL;
 mv_fileCount = 0;
//
 mv_errorText = "";
//
 mv_validFlag = false;
//
//
//  ** Exit **
//
}
//
//
//
//  *****************
//    ~CHs_CalibRef
//  *****************
//
CHs_CalibRef::~CHs_CalibRef()
//
//  Description : destructor
//
{
//
//
//  ** Class Data **
//
//  File
//
 Fv_CloseFile();
//
//  Class resources
//
 if (mv_pCalibIndex != NULL)  delete [] mv_pCalibIndex;
 if (mv_pCalibData  != NULL)  delete [] mv_pCalibData;
//
//
//  ** Exit **
//
}
//
//
//
//  ****************
//    F_Initialize
//  ****************
//
bool CHs_CalibRef::F_Initialize(CHm_OutFile *pNetwork,
                                double       finalElapsedTime,
                                int         &errorCode)
//
//  Description : initialise calibration data entry process
//
{
//
//
//  ** Initialisation **
//
 errorCode = 0;
//
 mv_pNetwork         = pNetwork;
 mv_finalElapsedTime = finalElapsedTime;
//
//
//  ** Get Quality Count **
//
 CHs_NetworkOut *pNetworkOut = (CHs_NetworkOut *) mv_pNetwork;
 mv_pollutantCount = pNetworkOut->F_GetPollutantCount();
//
//
//  ** Get Time Data: assumed in absolute day format **
//
 CHs_DateTime *pDateTime = (CHs_DateTime *) mh_pUnit->F_GetDateTime();
//
 mv_dateDelimiter   = pDateTime->F_GetTimeDateDelimiter();
 mv_simStartRefDays = pNetworkOut->F_GetSimStartAbsCalendarDay();  
 mv_simStartHour    = pNetworkOut->F_GetSimStartDecimalHour();
//
//
//  ** Get Available Data Filenames: from supporting calibration types **
//
 Fv_GetCalibFileData();
 if (mv_fileCount <= 0)  return true;
//
//
//  ** Get Calibration Data **
//
 if (!Fv_GetCalibData(errorCode))  return false;
//
//
//  ** Exit **
//
 return true;
}
//
//
//
//  ******************
//    F_SetTimeRange
//  ******************
//
bool CHs_CalibRef::F_SetTimeRange(double startElapsedTime,
                                  double endElapsedTime)
//
//  Description : set output data elapsed time range
//
{
//
//
//  ** Data Loop: for all defined data objects **
//
 for (int i = 0;  i < mv_calibCount;  i++)
  {
   if (mv_pCalibData[i].F_IsValid())
    {
//
//  Set time indices
//
     if (!mv_pCalibData[i].F_SetOutputTime(startElapsedTime,  
                                           endElapsedTime))  return false;
//
//  Set object time range data validity flag
//
     bool  validFlag = true;
//
     if (mv_pCalibData[i].F_GetOutputStartIndex() < 0)  
       validFlag = false;
     if (mv_pCalibData[i].F_GetOutputEndIndex() < 0)
       validFlag = false;
//
     mv_pCalibData[i].F_SetTimeRangeFlag(validFlag);
    }
  }
//
//
//  ** Exit **
//
 return true;
}
//
//
//
//  ************************
//    F_GetValidCalibCount
//  ************************
//
int CHs_CalibRef::F_GetValidCalibCount()
//
//  Description : get valid calibration data count
//
{
//
//
//  ** Initialisation **
//
 int  count = 0;
//
//
//  ** Check Loop: limited to objects with valid data values **
//
 for (int i = 0;  i < mv_calibCount;  i++)
  {
   if (mv_pCalibData[i].F_CheckValidity())
     count++;
  }
//
//
//  ** Exit **
//
 return count;
}
//
//
//
//  *******************
//    F_GetCalibIndex
//  *******************
//
int CHs_CalibRef::F_GetCalibIndex(int elementIndex,
                                  int elementType,
                                  int calibType,
                                  int pollutantIndex)
//
//  Description : get calibration data element index, default -1
//
{
//
//
//  ** Data Loop **
//
 for (int i = 0;  i < mv_calibCount;  i++)
  {
//
//  Screening: limited to objects with valid data values
//
   if (!mv_pCalibData[i].F_CheckValidity())  continue;
   if (!mv_pCalibData[i].F_CheckCalibData(elementIndex,
                                          elementType,
                                          calibType))  continue;
//
//  Additional processing for pollutant type
//
   if ((calibType == CHs_CalibData::EN_CalibType_NodePollutant) ||
       (calibType == CHs_CalibData::EN_CalibType_SubCatchPollutant))
    {
     int  calibIndex = i + pollutantIndex;
     if (!mv_pCalibData[calibIndex].F_CheckValidity())  return -1;
     return calibIndex;
    }
//
//  Standard Hydraulic types
//
   return i;
  }
//
//
//  ** Exit **
//
 return -1;
}
//
//
//
//  **********************
//    F_GetCalibDataSize
//  **********************
//
int CHs_CalibRef::F_GetCalibDataSize(int calibIndex)
//
//  Description : get calibration data item size within set time window
//
{
//
//
//  ** Check **
//
 if (calibIndex <  0)              return 0;
 if (calibIndex >= mv_calibCount)  return 0;
//
//
//  ** Get Data Item Size: within set time window **
//
 int  dataSize = mv_pCalibData[calibIndex].F_GetOutputCount();
//
//
//  ** Exit **
//
 return dataSize;
}
