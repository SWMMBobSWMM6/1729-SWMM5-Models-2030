//
//
//
//  *********************
//    F_CheckFileChange
//  *********************
//
bool CHs_CalibRef::F_CheckFileChange(int &errorCode)
//
//  Description : check potential calibration file change
//
{
//
//
//  ** Initialisation **
//
 errorCode = 0;
//
//
//  ** Check File Change **
//
 if (!Fv_CheckFileChange())  return true;
//
//
//  ** Re-Establish Calibration Files **
//
 Fv_SetCalibFileData();
//
//
//  ** Re-Enter Calibration Data **
//
 if (!Fv_GetCalibData(errorCode))  return false;
//
//
//  ** Exit **
//
 return true;
}
